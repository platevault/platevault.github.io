---
// Reveal-on-scroll progressive enhancement for the landing chapters.
// Runs inline (is:inline stops Astro from bundling/deferring it) so
// `reveal-init` lands on <html> before the chapter markup is parsed — the
// CSS hidden state in landing.css never flashes over already-visible
// content, and with JS disabled this script never runs, so chapters stay at
// their visible CSS default. Lives outside index.mdx because MDX parses
// `{`/`}` inside inline <script> children as JSX expressions.
---

<script is:inline>
	document.documentElement.classList.add('reveal-init');
	document.addEventListener('DOMContentLoaded', () => {
		const chapters = document.querySelectorAll('[data-has-hero] .pv-chapter');
		// No IntersectionObserver: reveal everything so nothing is stranded.
		if (!('IntersectionObserver' in window)) {
			chapters.forEach((el) => el.classList.add('is-visible'));
			return;
		}
		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (!entry.isIntersecting) continue;
					entry.target.classList.add('is-visible');
					io.unobserve(entry.target);
				}
			},
			{ rootMargin: '0px 0px -15% 0px' }
		);
		chapters.forEach((el) => {
			// Seed any chapter already in the initial viewport so it renders on
			// load instead of waiting for a scroll; only below-the-fold
			// chapters animate in on intersection.
			if (el.getBoundingClientRect().top < window.innerHeight * 0.92) {
				el.classList.add('is-visible');
			} else {
				io.observe(el);
			}
		});
	});
</script>
